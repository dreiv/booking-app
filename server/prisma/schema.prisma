generator client {
  provider = "prisma-client"
  output   = "../src/_generated/client"
}

datasource db {
  provider = "postgresql"
}

model Stay {
  id          String    @id @default(uuid())
  name        String
  description String
  location    String
  latitude    Float
  longitude   Float
  price       Float
  rating      Float     @default(0)
  images      String[]
  reviews     Review[]
  bookings    Booking[]
  createdAt   DateTime  @default(now())
}

model Review {
  id         String   @id @default(uuid())
  rating     Int // 1 - 5
  comment    String
  authorName String
  stayId     String
  stay       Stay     @relation(fields: [stayId], references: [id])
  createdAt  DateTime @default(now())
}

model Booking {
  id         String   @id @default(uuid())
  guestName  String
  guestEmail String
  checkIn    DateTime
  checkOut   DateTime
  totalPrice Float
  status     String   @default("CONFIRMED") //"PENDING", "CONFIRMED"
  stayId     String
  stay       Stay     @relation(fields: [stayId], references: [id])
  createdAt  DateTime @default(now())
}
