generator client {
  provider = "prisma-client"
  output   = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
}

model Stay {
  id          Int      @id @default(autoincrement())
  name        String
  location    String
  price       Float
  description String
  reviews     Review[]
}

model Review {
  id      Int    @id @default(autoincrement())
  comment String
  rating  Int
  stayId  Int
  stay    Stay   @relation(fields: [stayId], references: [id])
}
