{
  "name": "booking-app-server",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "lint": "oxlint . --fix -D correctness && eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "fix": "npm run format && npm run lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "db-gen": "prisma generate",
    "db-migrate": "prisma migrate dev",
    "db-seed": "prisma db seed",
    "db-setup": "npm run db-gen && npm run db-migrate && npm run db-seed"
  },
  "type": "module",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/ui": "^4.1.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "^1.61.0",
    "globals": "^17.5.0",
    "oxlint": "^1.61.0",
    "prettier": "^3.8.3",
    "prisma": "^7.7.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "oxlint --fix -D correctness",
      "eslint --fix",
      "prettier --write"
    ]
  }
}
